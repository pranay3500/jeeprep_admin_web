# Flutter web SPA: serve index.html for deep links (e.g. /unsubscribe).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# Block search engine indexing (admin CMS is not public).
<IfModule mod_headers.c>
  Header always set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
</IfModule>

# After deploy, browsers/CDN must not keep an old main.dart.js (wrong Firebase project).
<IfModule mod_headers.c>
  <FilesMatch "^(main\.dart\.js|version\.json|flutter_bootstrap\.js|favicon\.png|manifest\.json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "^Icon-.+\.png$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
